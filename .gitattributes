# Normalize line endings to LF on checkout for all text files
* text=auto eol=lf

# Force LF for shell scripts (must never have CRLF — breaks containers)
*.sh text eol=lf

# Force LF for Python and config files
*.py text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.env text eol=lf

# Binaries — no conversion
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.woff2 binary
*.woff binary
