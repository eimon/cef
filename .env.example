# =============================================================================
# CEF — Production Environment Variables
# Copy this file to .env and fill in the values before deploying.
# Used by docker-compose.prod.yml
# =============================================================================

# -----------------------------------------------------------------------------
# Security
# Must be a long, random string. Used for JWT signing (API) and
# JWT verification (Next.js frontend). Both services must share the same value.
# Generate with: openssl rand -hex 32
# -----------------------------------------------------------------------------
SECRET_KEY=

# JWT algorithm (default: HS256, no need to change unless you know why)
# ALGORITHM=HS256

# -----------------------------------------------------------------------------
# Database
# Password for the postgres user. Used by both the API (DATABASE_URL) and
# the db service (POSTGRES_PASSWORD).
# -----------------------------------------------------------------------------
POSTGRES_PASSWORD=

# -----------------------------------------------------------------------------
# Public registration email verification (Resend)
# RESEND_FROM_EMAIL must use a domain verified in Resend for production.
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL="CEF <no-reply@cef.ar>"
FRONTEND_PUBLIC_URL=https://cef.ar
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRE_HOURS=24

# -----------------------------------------------------------------------------
# Hostnames (for reverse proxy / Let's Encrypt)
# API_HOST: public domain for the FastAPI service  (e.g. api.cef.ar)
# HOST:     public domain for the Next.js frontend (e.g. cef.ar)
# -----------------------------------------------------------------------------
API_HOST=api.cef.ar
HOST=cef.ar
